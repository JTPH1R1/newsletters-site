---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const newsletters = await getCollection('newsletters');
  return newsletters.map(e => ({ params: { slug: e.slug }, props: { entry: e } }));
}

interface Props { entry: CollectionEntry<'newsletters'>; }
const { entry } = Astro.props;
const { Content } = await entry.render();
const {
  title, theme, excerpt, date, edition, readTime,
  question, numbers, tags,
  coverImage, coverAlt, coverCredit,
  advertImage, advertLink
} = entry.data;
const pageUrl = `https://readomg.netlify.app/newsletters/${entry.slug}`;

const all = await getCollection('newsletters');
const sorted = all.sort((a, b) => b.data.edition - a.data.edition);
const idx = sorted.findIndex(n => n.slug === entry.slug);
const prev = sorted[idx + 1];
const next = sorted[idx - 1];

function accentColor(tag: string = '') {
  const t = tag.toLowerCase();
  if (t.includes('economy') || t.includes('finance') || t.includes('agri')) return '#1DB864';
  if (t.includes('infra')) return '#2A7AE0';
  if (t.includes('africa') || t.includes('fintech')) return '#7B35D6';
  if (t.includes('life') || t.includes('wellness')) return '#E84A20';
  if (t.includes('tech') || t.includes('ai')) return '#5B35D6';
  return '#E8A020';
}
const topColor = accentColor(tags[0]);
---

<BaseLayout title={`${title} — Outreach Media Group`} description={excerpt}>
<style>
  :root{--page:#F7F4EF;--card:#fff;--ink:#1A1A1A;--muted:#6A6560;--rule:#E0DBD3;--flame:#D4521A;}
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
  html{font-size:16px;scroll-behavior:smooth;}
  body{background:var(--page);color:var(--ink);font-family:'Source Serif 4',Georgia,serif;}

  nav{background:var(--card);border-bottom:1px solid var(--rule);position:sticky;top:0;z-index:100;}
  .ni{max-width:820px;margin:0 auto;padding:.75rem clamp(1rem,4vw,1.5rem);display:flex;justify-content:space-between;align-items:center;gap:1rem;}
  .nb{font-family:'IBM Plex Mono',monospace;font-size:.6rem;color:var(--flame);text-decoration:none;letter-spacing:.08em;text-transform:uppercase;}
  .nb:hover{text-decoration:underline;}
  .nbrand{font-family:'Playfair Display',serif;font-size:.95rem;font-weight:700;color:var(--ink);}
  .nbrand em{color:var(--flame);font-style:normal;}
  .ned{font-family:'IBM Plex Mono',monospace;font-size:.58rem;color:var(--muted);}

  .art-outer{max-width:820px;margin:0 auto;padding:1.2rem clamp(1rem,4vw,1.5rem);}

  /* Cover image */
  .cover-wrap{position:relative;margin-bottom:0;}
  .cover-img{width:100%;max-height:420px;object-fit:cover;display:block;}
  .cover-credit{background:rgba(0,0,0,0.55);padding:4px 10px;font-family:'IBM Plex Mono',monospace;font-size:.58rem;color:rgba(255,255,255,.7);text-align:right;}
  .cover-credit a{color:rgba(255,255,255,.85);text-decoration:none;}
  .cover-credit a:hover{text-decoration:underline;}

  .art-card{background:var(--card);}
  .art-top{height:4px;}

  /* Header */
  .art-head{padding:1.8rem 2rem 1.4rem;border-bottom:1px solid var(--rule);}
  .art-badge{display:flex;gap:.6rem;align-items:center;flex-wrap:wrap;margin-bottom:.9rem;}
  .pill{font-family:'IBM Plex Mono',monospace;font-size:.56rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;padding:3px 8px;}
  .p-eco{background:#E8F7EE;color:#0A5C30;} .p-inf{background:#E6F0FC;color:#0A3A7A;}
  .p-afr{background:#F0EAFD;color:#4A1580;} .p-lif{background:#FDEEE8;color:#8C2A08;}
  .p-tec{background:#E8F0FC;color:#0A3070;} .p-glo{background:#FDF5E6;color:#704008;}
  .art-esrc{font-family:'IBM Plex Mono',monospace;font-size:.58rem;color:var(--muted);}
  .art-title{font-family:'Playfair Display',serif;font-size:clamp(1.4rem,4vw,2.1rem);font-weight:900;line-height:1.14;color:var(--ink);margin-bottom:.6rem;}
  .art-theme{font-family:'Source Serif 4',serif;font-style:italic;font-size:.95rem;color:var(--flame);margin-bottom:.9rem;line-height:1.5;}
  .art-meta{font-family:'IBM Plex Mono',monospace;font-size:.58rem;color:var(--muted);display:flex;gap:1rem;flex-wrap:wrap;}
  .art-meta b{color:var(--ink);}

  /* Body */
  .art-body{padding:1.8rem 2rem 0;}

  /* Story headlines from markdown */
  .art-body :global(h2){
    font-family:'Playfair Display',serif;
    font-size:1.2rem;font-weight:700;line-height:1.25;color:var(--ink);
    margin:2.5rem 0 .3rem;
    padding-left:.9rem;
    border-left:3px solid var(--flame);
  }

  /* Category labels */
  .art-body :global(h3){
    font-family:'IBM Plex Mono',monospace;font-size:.57rem;font-weight:600;
    letter-spacing:.15em;text-transform:uppercase;color:var(--flame);
    margin:.9rem 0 .3rem;
  }

  .art-body :global(h4){
    font-family:'IBM Plex Mono',monospace;font-size:.55rem;letter-spacing:.13em;
    text-transform:uppercase;color:#7A4A08;margin:.7rem 0 .3rem;
  }

  /* Body text */
  .art-body :global(p){
    font-family:'Source Serif 4',serif;font-size:.92rem;color:#3A3530;
    line-height:1.84;margin-bottom:.8rem;
  }

  /* ── SOURCE IMAGES ── */
  /* Images in the article body get full treatment */
  .art-body :global(img){
    width:100%;
    max-height:360px;
    object-fit:cover;
    display:block;
    margin:.8rem 0 0;
  }

  /* Caption/credit line after each image — targets <em> immediately after <img> */
  .art-body :global(p:has(img)){
    margin-bottom:0;
  }

  /* The credit line appears as italic text after the image */
  .art-body :global(p > img + br + em),
  .art-body :global(em:first-child){
    display:block;
    font-family:'IBM Plex Mono',monospace;
    font-style:normal;
    font-size:.58rem;
    color:#AAA;
    letter-spacing:.04em;
    background:#F7F4EF;
    padding:4px 10px;
    border-left:2px solid #D0CCC4;
    margin-bottom:1.2rem;
  }

  /* Rendered markdown: ![alt](url)\n*caption* becomes p>img then p>em */
  .art-body :global(p:has(img) + p > em:only-child){
    display:block;
    font-family:'IBM Plex Mono',monospace;
    font-style:normal;
    font-size:.58rem;
    color:#888;
    padding:4px 10px 8px;
    background:#F7F4EF;
    border-bottom:0.5px solid #E0DBD3;
    margin-bottom:1.4rem;
    margin-top:-0.8rem;
  }

  .art-body :global(a){color:var(--flame);text-decoration:none;}
  .art-body :global(a:hover){text-decoration:underline;}

  /* Source link in blockquote */
  .art-body :global(blockquote){
    background:#FDF6E8;border-left:3px solid #E8A020;
    padding:.7rem 1rem;margin:.9rem 0;border-radius:0;
  }
  .art-body :global(blockquote p){
    font-family:'Source Serif 4',serif;font-size:.84rem;
    color:#4A3010;line-height:1.6;margin:0;
  }
  .art-body :global(hr){border:none;border-top:1px solid var(--rule);margin:2.5rem 0;}
  .art-body :global(strong){color:var(--ink);}

  /* Numbers desk */
  .num-desk{background:#EDF4FC;border:1px solid #C0D8F4;padding:1.5rem;margin:2rem 0;}
  .nd-t{font-family:'IBM Plex Mono',monospace;font-size:.58rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:#0A3A7A;margin-bottom:1.2rem;display:flex;gap:.5rem;align-items:center;}
  .nd-row{display:grid;grid-template-columns:2fr 1.3fr 3fr;gap:.7rem;padding:.65rem 0;border-bottom:1px solid #C8DCEE;align-items:baseline;}
  .nd-row:last-child{border:none;}
  .nd-l{font-family:'IBM Plex Mono',monospace;font-size:.6rem;font-weight:600;color:#0A3A7A;}
  .nd-v{font-family:'IBM Plex Mono',monospace;font-size:.95rem;font-weight:700;color:var(--ink);}
  .nd-m{font-family:'Source Serif 4',serif;font-size:.8rem;color:#3A3530;line-height:1.5;}

  /* Question */
  .q-block{background:#FEF3EC;border-left:4px solid var(--flame);padding:1.2rem 1.5rem;margin:2rem 0;}
  .q-lbl{font-family:'IBM Plex Mono',monospace;font-size:.56rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--flame);margin-bottom:.5rem;}
  .q-text{font-family:'Playfair Display',serif;font-style:italic;font-size:1rem;color:#2A1A0A;line-height:1.55;}

  /* Tags */
  .tags-row{display:flex;gap:.4rem;flex-wrap:wrap;padding:1.2rem 0;border-top:1px solid var(--rule);}
  .tag{font-family:'IBM Plex Mono',monospace;font-size:.55rem;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);background:var(--page);border:0.5px solid var(--rule);padding:3px 8px;}

  /* Share */
  .share-bar{display:flex;gap:.5rem;align-items:center;padding:1.1rem 2rem;border-top:1px solid var(--rule);flex-wrap:wrap;}
  .share-l{font-family:'IBM Plex Mono',monospace;font-size:.56rem;text-transform:uppercase;letter-spacing:.1em;color:#AAA;margin-right:.3rem;}
  .share-btn{font-family:'IBM Plex Mono',monospace;font-size:.58rem;color:var(--ink);background:var(--page);border:0.5px solid var(--rule);padding:5px 12px;cursor:pointer;text-decoration:none;transition:background .15s;}
  .share-btn:hover{background:#EDE9E2;}

  /* Advert block */
  .advert-wrap{margin:2.5rem 0;border-top:1px solid var(--rule);border-bottom:1px solid var(--rule);padding:1rem 0;}
  .advert-label{font-family:'IBM Plex Mono',monospace;font-size:.52rem;letter-spacing:.14em;text-transform:uppercase;color:#AAA;text-align:center;margin-bottom:.6rem;}
  .advert-img{width:100%;max-height:200px;object-fit:cover;display:block;}
  .advert-link{display:block;} .advert-link:hover{opacity:.9;}

  /* Legal notice */
  .img-notice{background:var(--page);border-top:0.5px solid var(--rule);padding:.7rem 2rem;font-family:'IBM Plex Mono',monospace;font-size:.55rem;color:#AAA;line-height:1.6;}

  /* Prev/Next */
  .issue-nav{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--rule);margin-top:1px;}
  .in{background:var(--card);padding:1.1rem;text-decoration:none;color:inherit;transition:background .15s;}
  .in:hover{background:#FAFAF7;}
  .in-dir{font-family:'IBM Plex Mono',monospace;font-size:.56rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);display:block;margin-bottom:.35rem;}
  .in-title{font-family:'Playfair Display',serif;font-size:.85rem;font-weight:700;color:var(--ink);line-height:1.3;}
  .in-next{text-align:right;}

  footer{background:var(--ink);padding:1.2rem clamp(1rem,4vw,2rem);margin-top:1px;}
  .fi{max-width:820px;margin:0 auto;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.8rem;}
  .fb{font-family:'Playfair Display',serif;font-size:.9rem;font-weight:700;color:#F0EDE8;}
  .fb em{color:var(--flame);font-style:normal;}
  .fc{font-family:'IBM Plex Mono',monospace;font-size:.55rem;color:#666;text-align:right;}

  @media(max-width:600px){
    .art-head,.art-body,.share-bar,.img-notice{padding-left:1.2rem;padding-right:1.2rem;}
    .nd-row{grid-template-columns:1fr 1fr;}.nd-m{display:none;}
    .issue-nav{grid-template-columns:1fr;}.in-next{text-align:left;}
  }
</style>

  <nav>
    <div class="ni">
      <a href="/" class="nb">← All editions</a>
      <span class="nbrand">OUTREACH <em>MEDIA GROUP</em></span>
      <span class="ned">#{edition}</span>
    </div>
  </nav>

  <div class="art-outer">
    <div class="art-card">
      <div class="art-top" style={`background:${topColor};`}></div>

      {coverImage && (
        <div class="cover-wrap">
          <img src={coverImage} alt={coverAlt || title} class="cover-img" loading="eager" />
          {coverCredit && (
            <div class="cover-credit">
              Image: <a href="/" rel="noopener">{coverCredit}</a>
            </div>
          )}
        </div>
      )}

      <header class="art-head">
        <div class="art-badge">
          {tags.slice(0,2).map(t => <span class="pill p-eco">{t}</span>)}
          <span class="art-esrc">Edition #{edition} · {date}</span>
        </div>
        <h1 class="art-title">{title}</h1>
        <p class="art-theme">{theme}</p>
        <div class="art-meta">
          <span>By <b>JP</b> · Blantyre, Malawi</span>
          <span>{readTime}</span>
        </div>
      </header>

      <article class="art-body">
        <Content />

        {advertImage && (
          <div class="advert-wrap">
            <div class="advert-label">Advertisement</div>
            {advertLink ? (
              <a href={advertLink} class="advert-link" target="_blank" rel="noopener sponsored">
                <img src={advertImage} alt="Advertisement" class="advert-img" loading="lazy" />
              </a>
            ) : (
              <img src={advertImage} alt="Advertisement" class="advert-img" loading="lazy" />
            )}
          </div>
        )}

        {numbers.length > 0 && (
          <div class="num-desk">
            <div class="nd-t">📊 Today's key numbers</div>
            {numbers.map(n => (
              <div class="nd-row">
                <span class="nd-l">{n.label}</span>
                <span class="nd-v">{n.value}</span>
                <span class="nd-m">{n.meaning}</span>
              </div>
            ))}
          </div>
        )}

        {question && (
          <div class="q-block">
            <div class="q-lbl">💬 Today's conversation</div>
            <p class="q-text">{question}</p>
          </div>
        )}

        {tags.length > 0 && (
          <div class="tags-row">
            {tags.map(t => <span class="tag">{t}</span>)}
          </div>
        )}
      </article>

      <div class="img-notice">
        Images sourced from original publishers via Open Graph metadata and used for editorial news commentary purposes with full attribution.
        All rights belong to their respective owners. Links in each caption lead back to the original source.
      </div>

      <div class="share-bar">
        <span class="share-l">Share</span>
        <a class="share-btn" href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(pageUrl)}`} target="_blank" rel="noopener">Twitter / X</a>
        <a class="share-btn" href={`https://wa.me/?text=${encodeURIComponent(`Outreach Media Group — ${title}\n\n${excerpt}\n\n${pageUrl}`)}`} target="_blank" rel="noopener">WhatsApp</a>
        <a class="share-btn" href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(pageUrl)}`} target="_blank" rel="noopener">LinkedIn</a>
      </div>
    </div>

    <nav class="issue-nav">
      {prev ? (
        <a href={`/newsletters/${prev.slug}`} class="in">
          <span class="in-dir">← Previous edition</span>
          <span class="in-title">{prev.data.title}</span>
        </a>
      ) : <div style="background:var(--card);"></div>}
      {next ? (
        <a href={`/newsletters/${next.slug}`} class="in in-next">
          <span class="in-dir">Next edition →</span>
          <span class="in-title">{next.data.title}</span>
        </a>
      ) : <div style="background:var(--card);"></div>}
    </nav>
  </div>

  <footer>
    <div class="fi">
      <span class="fb">OUTREACH <em>MEDIA GROUP</em></span>
      <div class="fc"><div>© {new Date().getFullYear()} Outreach Media Group · Blantyre, Malawi</div></div>
    </div>
  </footer>

</BaseLayout>
